{
  "name": "cloud_cost_analyzer",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "dev:api": "turbo -F @cloud_cost_analyzer/api dev",
    "db:push": "turbo -F @cloud_cost_analyzer/db db:push",
    "db:studio": "turbo -F @cloud_cost_analyzer/db db:studio",
    "db:generate": "turbo -F @cloud_cost_analyzer/db db:generate",
    "db:migrate": "turbo -F @cloud_cost_analyzer/db db:migrate",
    "db:start": "turbo -F @cloud_cost_analyzer/db db:start",
    "db:watch": "turbo -F @cloud_cost_analyzer/db db:watch",
    "db:stop": "turbo -F @cloud_cost_analyzer/db db:stop",
    "db:down": "turbo -F @cloud_cost_analyzer/db db:down"
  },
  "dependencies": {
    "@cloud_cost_analyzer/env": "*",
    "dotenv": "^17.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@cloud_cost_analyzer/config": "*",
    "@types/bun": "^1.3.4",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "npm@10.9.2"
}